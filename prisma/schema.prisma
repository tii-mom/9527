generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }
model User { id String @id apiToken String @unique email String? @unique githubId String? @unique walletAddress String? status String @default("active") createdAt DateTime @default(now()) updatedAt DateTime @updatedAt devices Device[] sessions AdSession[] account PointAccount? ledger PointLedger[] redemptions RedemptionOrder[] cryptoPayouts CryptoPayout[] }
model Device { id String @id userId String deviceHash String os String? cliVersion String? status String @default("active") createdAt DateTime @default(now()) user User @relation(fields:[userId], references:[id]) sessions AdSession[] @@index([userId]) }
model Campaign { id String @id sponsorName String headline String body String targetUrl String rewardPoints Int @default(5) clickRewardPoints Int @default(0) cpaRewardPoints Int @default(0) pricingModel String @default("manual") budgetCents Int @default(0) spentCents Int @default(0) status String @default("active") tags Json? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt sessions AdSession[] }
model AdSession { id String @id claimToken String @unique userId String deviceId String campaignId String status String @default("created") rewardPoints Int @default(0) ipHash String? userAgent String? context Json? createdAt DateTime @default(now()) shownAt DateTime? viewedAt DateTime? clickedAt DateTime? completedAt DateTime? rewardedAt DateTime? expiresAt DateTime user User @relation(fields:[userId],references:[id]) device Device @relation(fields:[deviceId],references:[id]) campaign Campaign @relation(fields:[campaignId],references:[id]) @@index([userId]) @@index([deviceId]) @@index([campaignId]) }
model PointAccount { userId String @id pendingPoints Int @default(0) availablePoints Int @default(0) lockedPoints Int @default(0) redeemedPoints Int @default(0) expiredPoints Int @default(0) updatedAt DateTime @updatedAt user User @relation(fields:[userId],references:[id]) }
model PointLedger { id String @id userId String sourceType String sourceId String? eventType String points Int status String @default("pending") description String? createdAt DateTime @default(now()) availableAt DateTime? user User @relation(fields:[userId],references:[id]) @@index([userId]) @@index([status]) }
model ShopItem { id String @id category String name String description String? pointsPrice Int referenceValueCents Int? stock Int? provider String? deliveryType String requiresReview Boolean @default(false) requiresWallet Boolean @default(false) requiresKyc Boolean @default(false) supportedRegions Json? metadata Json? status String @default("active") createdAt DateTime @default(now()) updatedAt DateTime @updatedAt redemptions RedemptionOrder[] }
model RedemptionOrder { id String @id userId String itemId String pointsCost Int status String @default("pending") deliveryType String deliveryPayload Json? riskStatus String @default("pending") createdAt DateTime @default(now()) completedAt DateTime? user User @relation(fields:[userId],references:[id]) item ShopItem @relation(fields:[itemId],references:[id]) cryptoPayout CryptoPayout? @@index([userId]) @@index([status]) }
model CryptoPayout { id String @id redemptionOrderId String @unique userId String asset String chain String amount String walletAddress String status String @default("pending") txHash String? riskReviewResult String? createdAt DateTime @default(now()) paidAt DateTime? redemptionOrder RedemptionOrder @relation(fields:[redemptionOrderId],references:[id]) user User @relation(fields:[userId],references:[id]) }
